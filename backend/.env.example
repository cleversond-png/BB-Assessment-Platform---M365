# Azure App Registration (multi-tenant)
AZURE_CLIENT_ID=your-client-id-here
AZURE_CLIENT_SECRET=your-client-secret-here
AZURE_REDIRECT_URI=http://localhost:3000/auth/callback

# Server
PORT=3000
NODE_ENV=development

# Portal login (optional overrides)
PORTAL_ADMIN_USERNAME=Admin.Assessment
# Generate with: node -e 'const crypto=require("crypto"); const p="your-password"; const s=crypto.randomBytes(16).toString("hex"); const i=210000; console.log(`pbkdf2:${i}:${s}:${crypto.pbkdf2Sync(p,s,i,32,"sha256").toString("hex")}`)'
PORTAL_ADMIN_PASSWORD_HASH=pbkdf2:210000:...
